#!/usr/bin/env bash
#
# usage: ./run command [argument ...]
#
# Commands for halos-halpi-desktop-branding development.
#

set -o nounset
set -o pipefail
set -o errexit

# Change the current directory to the project root.
PROJECT_ROOT=${0%/*}
if [[ $0 != $PROJECT_ROOT && $PROJECT_ROOT != "" ]]; then
  cd "$PROJECT_ROOT"
fi
readonly PROJECT_ROOT=$(pwd)
readonly SCRIPT="$PROJECT_ROOT/$(basename "$0")"

################################################################################
# Helper Functions

function debtools {
  docker compose -f docker/docker-compose.debtools.yml run --rm debtools "$@"
}

################################################################################
# Debian Package Building Commands

function build-deb {
  #@ Build Debian package in debtools container
  #@ Category: Debian
  echo "📦 Building Debian package..."
  debtools \
    bash -c "dpkg-buildpackage -b -uc -us && mv ../*.deb ../*.buildinfo ../*.changes ./ 2>/dev/null || true"
  echo "📦 Generated packages:"
  ls -lh halos-halpi-desktop-branding*.deb 2>/dev/null || echo "⚠️  No .deb files found"
  echo "✅ Package build complete"
}

function lint-deb {
  #@ Check package quality with lintian
  #@ Category: Debian
  echo "🔍 Running lintian..."
  debtools lintian --info --display-info --pedantic *.deb
}

function bumpversion {
  #@ Bump version using bumpversion + dch
  #@ Category: Debian
  local part="${1:-patch}"
  echo "📈 Bumping ${part} version..."
  debtools bash -c "bumpversion ${part} && dch -v \$(cat VERSION) -D unstable --force-distribution 'Release \$(cat VERSION)'"
}

################################################################################
# Docker Management Commands

function build-debtools {
  #@ Build Debian packaging Docker image
  #@ Category: Docker
  echo "🐳 Building Debian packaging Docker image..."
  docker compose -f docker/docker-compose.debtools.yml build debtools
  echo "✅ Docker image built successfully"
}

function clean-debtools {
  #@ Remove Debian packaging Docker containers and images
  #@ Category: Docker
  echo "🧹 Cleaning Debian packaging Docker containers and images..."
  docker compose -f docker/docker-compose.debtools.yml down --rmi all --volumes
  echo "✅ Docker cleanup complete"
}

################################################################################
# Deploy Commands

function deploy {
  #@ Deploy .deb package to test server
  #@ Category: Deploy
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    echo "Usage: ./run deploy <target>"
    echo "Example: ./run deploy pi@halosdev.local"
    return 1
  fi
  local deb_file
  deb_file=$(ls -t halos-halpi-desktop-branding*.deb 2>/dev/null | head -1)
  if [ -z "$deb_file" ]; then
    echo "❌ No .deb file found. Run ./run build-deb first."
    exit 1
  fi
  echo "📦 Deploying $deb_file to $target..."
  scp "$deb_file" "$target:/tmp/"
  ssh "$target" "sudo apt install -y --allow-downgrades /tmp/$(basename "$deb_file")"
  echo "✅ Deployment complete."
}

function deploy-build {
  #@ Build and deploy to test server
  #@ Category: Deploy
  build-deb
  deploy "$@"
}

function status {
  #@ Show installed package version on test server
  #@ Category: Deploy
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    echo "Usage: ./run status <target>"
    return 1
  fi
  ssh "$target" "dpkg -l | grep halos-halpi-desktop-branding || echo 'Not installed'"
}

################################################################################
# Utility Commands

function clean {
  #@ Clean build artifacts
  #@ Category: Utility
  echo "🧹 Cleaning build artifacts..."
  rm -f *.deb *.buildinfo *.changes
  rm -rf debian/.debhelper debian/halos-halpi-desktop-branding debian/debhelper-build-stamp debian/files debian/*.substvars debian/*.log
  rm -f etc/xdg/pcmanfm/default/desktop-items-1.conf
  echo "✅ Cleanup complete"
}

function install-hooks {
  #@ Install lefthook pre-commit hooks
  #@ Category: Utility
  if ! command -v lefthook >/dev/null 2>&1; then
    echo "❌ lefthook not installed. Install with: brew install lefthook"
    return 1
  fi
  lefthook install
  echo "✅ Hooks installed."
}

################################################################################
# Help System

function help {
  #@ Show this help message
  #@ Category: Core
  echo "halos-halpi-desktop-branding - Development Commands"
  echo "==================================================="
  echo ""
  echo "Available commands:"
  echo ""

  awk '/^function / {
    fname = $2
    sub(/[({].*/, "", fname)
    getline
    if ($0 ~ /#@/) {
      desc = $0
      sub(/.*#@ /, "", desc)
      sub(/ *$/, "", desc)
      getline
      if ($0 ~ /#@ Category:/) {
        cat = $0
        sub(/.*Category: /, "", cat)
        sub(/ *$/, "", cat)
        if (!seen[cat]++) categories[++cat_count] = cat
        commands[cat, ++cmd_count[cat]] = fname
        descriptions[cat, cmd_count[cat]] = desc
      }
    }
  }
  END {
    for (i = 1; i <= cat_count; i++) {
      cat = categories[i]
      print "\n" cat ":"
      for (j = 1; j <= cmd_count[cat]; j++) {
        printf "  %-25s %s\n", commands[cat, j], descriptions[cat, j]
      }
    }
  }' "$0"

  echo ""
  echo "Usage: ./run <command> [arguments...]"
  echo ""
  echo "Quick start:"
  echo "  1. ./run build-debtools    # Build packaging container (first time)"
  echo "  2. ./run build-deb         # Build .deb package"
  echo "  3. ./run lint-deb          # Check package quality"
  echo ""
}

################################################################################
# Commands end.

TIMEFORMAT=$'\nTask completed in %3lR'
time "${@:-help}"
